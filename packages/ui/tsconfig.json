{
	"extends": "@workspace/typescript-config/react-library.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@workspace/ui/*": ["./src/*"]
		},
		"moduleResolution": "node16",
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"noEmit": true
	},
	"include": ["."],
	"exclude": ["node_modules", "dist"]
}
