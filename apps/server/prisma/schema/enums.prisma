// prisma/schema/enums.prisma

enum UserRole {
  // Global super admin for the entire platform
  ADMIN
  // Admin for a specific company or branch - manages that organization
  COMPANY_SUPER_ADMIN
  // Internal employee working for a company - limited access based on feature assignment
  COMPANY_STAFF
  // External partner like dealer or repair shop - belongs to branch organization
  COMPANY_PARTNER
  // End customer who buys products and registers warranties
  CONSUMER
}

enum OrganizationType {
  // Top-level parent company - the main tenant
  ROOT
  // Child organization - dealer, partner, regional office under a ROOT
  BRANCH
}

enum OtpType {
  // OTP for passwordless login
  LOGIN
  // OTP to recover account when password is forgotten
  PASSWORD_RESET
  // OTP to verify email address during signup
  VERIFY_EMAIL
  // OTP to verify mobile number during signup
  VERIFY_PHONE
}

enum FeatureStatus {
  // Planned but not yet available to anyone - shows "Coming Soon" badge
  COMING_SOON
  // Available globally - can be assigned to users
  ENABLED
  // Temporarily turned off globally - hidden from UI, not assignable
  DISABLED
}