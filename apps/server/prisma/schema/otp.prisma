// prisma/schema/otp.prisma

model OtpVerification {
  // Primary key - auto-generated UUID
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // User who requested this OTP code
  userId      String    @db.Uuid

  // The actual OTP code sent to the user (typically 6-digit number)
  code        String

  // Purpose of this OTP - LOGIN, PASSWORD_RESET, VERIFY_EMAIL, VERIFY_PHONE
  type        OtpType

  // Exact timestamp when this OTP expires and becomes invalid (typically 10 minutes from creation)
  expiresAt   DateTime  @db.Timestamptz

  // Security flag - set to true after successful use to prevent replay attacks
  isUsed      Boolean   @default(false)

  // Timestamp when this OTP was generated
  createdAt   DateTime  @default(now()) @db.Timestamptz

  // --- Relations ---

  // User who requested this OTP (deleted if user is deleted)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for fast verification lookups
  @@index([userId])
  @@index([code])
}