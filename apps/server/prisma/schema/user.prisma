// prisma/schema/user.prisma

model User {
  // Primary key - auto-generated UUID
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Login identifiers (unique across platform)
  email         String?   @unique
  phoneNumber   String?   @unique
  
  // Personal info
  firstName     String
  lastName      String
  fullName      String
  
  // Authentication
  passwordHash  String?
  role          UserRole  @default(CONSUMER)
  
  // Verification flags
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  
  // Status
  isActive      Boolean   @default(true)
  
  // Profile
  profile       String?

  // Timestamps
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  
  // Soft delete
  deletedAt     DateTime? @db.Timestamptz
  deletedBy     String?

  // --- OTP ---
  otpRequests           OtpVerification[] 
  
  // --- Organization Membership ---
  accessProfiles        UserAccess[]
  
  // --- Form Data ---
  createdForms          FormData[] @relation("FormDataCreator")
  updatedForms          FormData[] @relation("FormDataUpdater")

  // --- Organization Audit ---
  createdOrganizations  Organization[] @relation("OrganizationCreator")
  updatedOrganizations  Organization[] @relation("OrganizationUpdater")

  // --- Feature Audit ---
  createdFeatures       Feature[]        @relation("FeatureCreator")
  updatedFeatures       Feature[]        @relation("FeatureUpdater")
  
  // --- Feature Access ---
  featureAccess         FeatureAccess[]  @relation("UserFeatureAccess")
  updatedFeatureAccess  FeatureAccess[]  @relation("FeatureAccessUpdater")

  createdCategories   Category[] @relation("CategoryCreator")
  updatedCategories   Category[] @relation("CategoryUpdater")
  createdBrands       Brand[]    @relation("BrandCreator")
  updatedBrands       Brand[]    @relation("BrandUpdater")

  // Indexes
  @@index([email])
  @@index([phoneNumber])
  @@index([role])
}