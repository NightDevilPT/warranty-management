// prisma/schema/permissions.prisma

model Persona {
  // Primary key for the permission
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // System name of the permission (e.g., "Create Product")
  name                 String
  // User-friendly label shown in the UI toggles
  label                String
  // Dynamic string code used in the backend to authorize an action (e.g., "CAN_CREATE_PRODUCT")
  code                 String                @unique
  // Explains what this permission actually allows the user to do
  description          String?
  // Master toggle allowing Platform Admins to disable a feature globally
  isActive             Boolean               @default(true)

  // --- Reverse Relations ---
  organizationPersonas OrganizationPersona[]
  dealerPersonas       DealerPersona[]
  dealerTypePersonas   DealerTypePersona[]
}

model OrganizationPersona {
  // Primary key for this company-to-permission link
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Foreign key linking to the company
  orgId       String       @db.Uuid
  // Foreign key linking to the allowed permission
  personaId   String       @db.Uuid
  
  // Allows the company admin to turn this feature on or off for their whole tenant
  isActive    Boolean      @default(true)
  // Tracks the ID or Role of the admin who granted this permission to this company
  enabledBy   String

  // --- Relations ---
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  persona      Persona      @relation(fields: [personaId], references: [id], onDelete: Restrict)

  // Ensures a company is only granted a specific permission once
  @@unique([orgId, personaId])
}

model DealerType {
  // Primary key for this company-defined role
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Foreign key linking this role to the company that created it
  orgId              String              @db.Uuid
  // The name of the role (e.g., "Retailer", "Installer")
  name               String
  // Defines if this role is meant for INTERNAL staff or EXTERNAL partners
  partnerType        String
  // Toggle to activate or deactivate this role entirely
  isActive           Boolean             @default(true)

  // --- Relations ---
  organization       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userAccesses       UserAccess[]
  dealerTypePersonas DealerTypePersona[]
  dealerPersonas     DealerPersona[]
}

model DealerTypePersona {
  // Primary key linking a role to a permission
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Foreign key pointing to the role (DealerType)
  dealerTypeId String     @db.Uuid
  // Foreign key pointing to the permission (Persona) to grant
  personaId    String     @db.Uuid
  
  // Allows admins to easily toggle specific permissions on/off within a role
  isActive     Boolean    @default(true)

  // --- Relations ---
  dealerType   DealerType @relation(fields: [dealerTypeId], references: [id], onDelete: Cascade)
  persona      Persona    @relation(fields: [personaId], references: [id], onDelete: Restrict)

  // Ensures a role isn't granted the exact same permission twice
  @@unique([dealerTypeId, personaId])
}

model DealerPersona {
  // Primary key for the final resolved permission given to a specific user
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Foreign key pointing to the User
  userId       String       @db.Uuid
  // Foreign key pointing to the Company, ensuring they only have this permission HERE
  orgId        String       @db.Uuid
  // Foreign key pointing to the actual permission
  personaId    String       @db.Uuid
  
  // Foreign key pointing to the role that granted this. Null if granted directly by an admin.
  dealerTypeId String?      @db.Uuid
  
  // Allows an admin to temporarily revoke a specific permission for just this user
  isActive     Boolean      @default(true)
  // Tracks if this was assigned by "SYSTEM" (via role) or manually by an Admin ID
  assignedBy   String

  // --- Relations ---
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  persona      Persona      @relation(fields: [personaId], references: [id], onDelete: Restrict)
  dealerType   DealerType?  @relation(fields: [dealerTypeId], references: [id], onDelete: SetNull)

  // Prevents a user from having duplicate permission records in the same company
  @@unique([userId, orgId, personaId])
}