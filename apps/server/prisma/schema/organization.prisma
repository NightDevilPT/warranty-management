// prisma/schema/organization.prisma

model Organization {
  // Primary key - auto-generated UUID for security
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Display name shown in UI (e.g., "Acme North America")
  name            String
  
  // Official registered business name for legal documents
  companyName     String
  
  // URL-friendly unique identifier for path-based routing
  // Example: "acme" → domain.com/acme/login
  slug            String           @unique
  
  // Organization logo URL (stored in S3)
  logo            String?
  
  // Organization hierarchy type
  // ROOT: Top-level parent company (main tenant)
  // BRANCH: Child organization (dealer, partner, regional office)
  type            OrganizationType @default(ROOT)
  
  // Master switch to activate/deactivate entire organization
  isActive        Boolean          @default(true)

  // Admin user ID who onboarded/created this organization
  createdBy       String?          @db.Uuid
  
  // Admin user ID who last modified this organization
  updatedBy       String?          @db.Uuid

  // Timestamps
  createdAt       DateTime         @default(now()) @db.Timestamptz
  updatedAt       DateTime         @updatedAt @db.Timestamptz

  // --- Hierarchy Relations ---
  rootId          String?          @db.Uuid
  root            Organization?    @relation("RootToNode", fields: [rootId], references: [id])
  nodesUnderRoot  Organization[]   @relation("RootToNode")

  parentId        String?          @db.Uuid
  parent          Organization?    @relation("ParentToChild", fields: [parentId], references: [id])
  children        Organization[]   @relation("ParentToChild")

  // --- Audit Relations ---
  creator         User?            @relation("OrganizationCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater         User?            @relation("OrganizationUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  // --- Feature Access ---
  featureAccess   FeatureAccess[]

  // --- User Access ---
  userAccesses    UserAccess[]

  // --- Categories & Brands ---
  categories      Category[]
  brands          Brand[]

  // --- Forms & Data ---
  formSchemas     FormSchema[]
  formData        FormData[]

  // --- Warranty ---
  warrantyTemplates WarrantyTemplate[]

  @@index([slug])
}