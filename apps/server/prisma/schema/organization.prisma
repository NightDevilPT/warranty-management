// prisma/schema/organization.prisma

model Organization {
  // Primary key - auto-generated UUID for security
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Display name shown in UI (e.g., "Acme North America")
  name String

  // Official registered business name for legal documents
  companyName String

  // URL-friendly unique identifier for internal reference
  slug String @unique

  // Organization logo URL stored in S3 bucket
  logo String?

  // Organization hierarchy type - ROOT (top-level parent) or BRANCH (child organization)
  type OrganizationType @default(ROOT)

  // Master switch to activate/deactivate entire organization - false locks out ALL users
  isActive Boolean @default(true)

  // Public hash for URL routing - "a3f2b8c1" → domain.com/a3f2b8c1/login
  hash String @unique

  // UserAccess ID who onboarded/created this organization
  createdBy String? @db.Uuid

  // UserAccess ID who last modified this organization
  updatedBy String? @db.Uuid

  // Timestamp when organization was first created/onboarded
  createdAt DateTime @default(now()) @db.Timestamptz

  // Timestamp automatically updated on every modification
  updatedAt DateTime @updatedAt @db.Timestamptz

  // Soft-delete timestamp - when set, organization is considered deleted
  // Slug and hash become available for reuse after deletion
  deletedAt DateTime? @db.Timestamptz

  // UserAccess ID who performed the soft-delete
  deletedBy String? @db.Uuid

  // --- Hierarchy Relations ---

  // Points to the ultimate top-level root organization for data isolation - null for ROOT, set for BRANCH
  rootId String? @db.Uuid

  // Reference to the root organization (top-level parent)
  root Organization? @relation("RootToNode", fields: [rootId], references: [id])

  // All branches/children under this root organization
  nodesUnderRoot Organization[] @relation("RootToNode")

  // Points to the immediate parent organization - null for ROOT, set for BRANCH
  parentId String? @db.Uuid

  // Reference to the immediate parent organization
  parent Organization? @relation("ParentToChild", fields: [parentId], references: [id])

  // All immediate child organizations under this parent
  children Organization[] @relation("ParentToChild")

  // --- Audit Relations ---

  // UserAccess who created this organization
  creator UserAccess? @relation("OrganizationCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  // UserAccess who last updated this organization
  updater UserAccess? @relation("OrganizationUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  // UserAccess who deleted this organization
  deleter UserAccess? @relation("OrganizationDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)

  // --- Feature Access ---

  // All feature access records for users in this organization
  featureAccess FeatureAccess[]

  // --- User Access ---

  // All users and their access profiles within this organization
  userAccesses UserAccess[]

  // --- Categories & Brands ---

  // Product categories defined for this organization
  categories Category[]

  // Product brands defined for this organization
  brands Brand[]

  // --- Dealer Types ---

  // Role templates created by this organization's admins
  dealerTypes DealerType[]

  // --- Forms & Data ---

  // Custom form structures (Product, Claim schemas) built for this organization
  formSchemas FormSchema[]

  // Actual form data records belonging to this organization
  formData FormData[]

  // --- Warranty ---

  // Warranty rules and templates configured for this organization
  warrantyTemplates WarrantyTemplate[]

  // Index for fast tenant resolution from URL hash
  @@index([slug])
  @@index([deletedAt])
}
