// prisma/schema/userAccess.prisma

model UserAccess {
  // Primary key
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Foreign keys
  userId        String    @db.Uuid
  orgId         String    @db.Uuid
  
  // Portal type: STAFF (internal dashboard) or CONSUMER (public portal)
  portalType    String
  
  // Role within this organization
  // COMPANY_SUPER_ADMIN, COMPANY_STAFF, COMPANY_PARTNER, CONSUMER
  role          String?
  
  // Partner type: INTERNAL or EXTERNAL
  partnerType   String?

  // Timestamps
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  // --- Relations ---
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // One user, one profile per organization
  @@unique([userId, orgId])
  
  @@index([userId])
  @@index([orgId])
  @@index([portalType])
}