// prisma/schema/feature.prisma

model Feature {
  // Primary key - auto-generated UUID for security
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Display name shown in UI (e.g., "Product Management", "Create Warranty")
  name String

  // Unique code for backend permission checks - Format: UPPERCASE with underscores, e.g., "PRODUCT_CREATE"
  code String @unique

  // Optional description explaining what this feature/module allows users to do
  description String?

  // Icon identifier for UI rendering (e.g., "package", "shield-check", "users")
  icon String?

  // Parent feature ID for building feature hierarchy/tree - null = root level module, set = sub-module
  parentId String? @db.Uuid

  // Sort order within the same parent level - lower numbers appear first in UI
  sortOrder Int @default(0)

  // Global status controlling feature availability - COMING_SOON, ENABLED, DISABLED
  status FeatureStatus @default(COMING_SOON)

  // UserAccess ID who created this feature
  createdBy String? @db.Uuid

  // UserAccess ID who last modified this feature
  updatedBy String? @db.Uuid

  // Timestamp when this feature was first created
  createdAt DateTime @default(now()) @db.Timestamptz

  // Timestamp automatically updated on every modification
  updatedAt DateTime @updatedAt @db.Timestamptz

  // --- Hierarchy Relations ---

  // Parent feature in the hierarchy tree (null for root modules)
  parent Feature? @relation("FeatureHierarchy", fields: [parentId], references: [id], onDelete: SetNull)

  // Child features under this parent (sub-modules, actions, permissions)
  children Feature[] @relation("FeatureHierarchy")

  // --- Audit Relations ---

  // UserAccess who created this feature
  creator UserAccess? @relation("FeatureCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  // UserAccess who last updated this feature
  updater UserAccess? @relation("FeatureUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  // --- Access Relations ---

  // All feature access records for dealer types in organizations
  featureAccess FeatureAccess[]

  // Unique constraint: same code cannot exist twice under same parent
  @@unique([parentId, code])

  // Indexes for faster lookups
  @@index([code])       // Find feature by unique code
  @@index([status])     // Filter features by status
  @@index([parentId])   // Find all children of a parent feature
}

// FeatureAccess links features to DealerTypes (role templates), NOT users
// Each record = one feature assigned to one dealer type in one organization
// Users inherit features through their UserAccess.dealerTypeId
model FeatureAccess {
  // Primary key - auto-generated UUID
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Organization ID - which organization this access belongs to
  orgId String @db.Uuid

  // DealerType ID - which dealer type (role template) this feature is assigned to
  dealerTypeId String @db.Uuid

  // Feature ID - which feature/module/permission this access controls
  featureId String @db.Uuid

  // Whether this feature is active for this dealer type - true = accessible, false = blocked
  isActive Boolean @default(true)

  // Timestamp when the feature was enabled
  enabledAt DateTime? @db.Timestamptz

  // Timestamp when the feature was disabled
  disabledAt DateTime? @db.Timestamptz

  // UserAccess ID who last modified this access record
  updatedBy String? @db.Uuid

  // Timestamp when this access record was created
  createdAt DateTime @default(now()) @db.Timestamptz

  // Timestamp automatically updated on every modification
  updatedAt DateTime @updatedAt @db.Timestamptz

  // --- Relations ---

  // Organization this access belongs to
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // DealerType this feature is assigned to
  dealerType DealerType @relation(fields: [dealerTypeId], references: [id], onDelete: Cascade)

  // Feature this access controls
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  // UserAccess who last modified this access
  updater UserAccess? @relation("FeatureAccessUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Unique constraint: one access record per org + dealerType + feature combination
  @@unique([orgId, dealerTypeId, featureId])

  // Indexes for faster lookups
  @@index([orgId])          // Find all features for an organization
  @@index([dealerTypeId])   // Find all features for a specific dealer type
  @@index([featureId])      // Find all access records for a feature
}