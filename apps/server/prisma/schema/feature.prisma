// prisma/schema/feature.prisma

// Status of a feature - controls availability
// COMING_SOON: Planned but not yet available to anyone
// ENABLED: Available globally, can be assigned to orgs/users
// DISABLED: Temporarily turned off globally
enum FeatureStatus {
  COMING_SOON
  ENABLED
  DISABLED
}

model Feature {
  // Primary key - auto-generated UUID for security
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Display name shown in UI (e.g., "Product Management", "Create Warranty")
  name        String
  
  // Unique code used by backend for permission checks (e.g., "PRODUCT", "WARRANTY_CLAIMS_CREATE")
  // Format: UPPERCASE with underscores, e.g., "MODULE_SUBMODULE_ACTION"
  code        String        @unique
  
  // Optional description explaining what this feature allows users to do
  description String?
  
  // Icon identifier for UI rendering (e.g., "package", "shield-check", "users")
  icon        String?
  
  // Parent feature ID for building feature hierarchy/tree
  // null = root level module (top-level)
  // set = sub-module or action under a parent
  parentId    String?       @db.Uuid
  
  // Sort order within the same parent level (lower = first)
  // Root features: controls order in sidebar
  // Child features: controls order in dropdown/expansion
  sortOrder   Int           @default(0)
  
  // Global status controlling feature availability
  // COMING_SOON: Not assignable, shows "Coming Soon" badge
  // ENABLED: Fully available for assignment
  // DISABLED: Hidden from UI, not assignable
  status      FeatureStatus @default(COMING_SOON)
  
  // User ID of the admin who created this feature
  createdBy   String?       @db.Uuid
  
  // User ID of the admin who last modified this feature
  updatedBy   String?       @db.Uuid
  
  // Timestamp when this feature was first created
  createdAt   DateTime      @default(now()) @db.Timestamptz
  
  // Timestamp automatically updated on every modification
  updatedAt   DateTime      @updatedAt @db.Timestamptz

  // --- Hierarchy Relations ---
  // Parent feature in the hierarchy tree (null for root modules)
  parent      Feature?      @relation("FeatureHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  
  // Child features under this parent (sub-modules, actions, permissions)
  children    Feature[]     @relation("FeatureHierarchy")

  // --- Audit Relations ---
  // Admin user who created this feature
  creator     User?         @relation("FeatureCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  
  // Admin user who last updated this feature
  updater     User?         @relation("FeatureUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  
  // --- Access Relations ---
  // All access records linking this feature to organizations and users
  featureAccess FeatureAccess[]

  // Unique constraint: same code cannot exist twice under same parent
  @@unique([parentId, code])
  
  // Indexes for faster lookups
  @@index([code])       // Find feature by unique code
  @@index([status])     // Filter features by status (ENABLED/DISABLED/COMING_SOON)
  @@index([parentId])   // Find all children of a parent feature
}

// Single table for managing feature access at both Organization and User level
// userId = null → Organization-level access (applies to entire org)
// userId = set → User-level access (applies to specific user within org)
model FeatureAccess {
  // Primary key - auto-generated UUID
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Organization ID - which organization this access belongs to
  orgId       String    @db.Uuid
  
  // User ID - who this access is for
  // null = Organization-level feature (defines what's available to the org)
  // set = User-level feature (defines what a specific user can access)
  userId      String?   @db.Uuid
  
  // Feature ID - which feature/module/permission this access controls
  featureId   String    @db.Uuid
  
  // Whether this feature is active/accessible
  // true = Feature is accessible to the org/user
  // false = Feature is hidden/blocked for the org/user
  isActive    Boolean   @default(true)
  
  // Timestamp when the feature was enabled
  // Set when isActive changes from false to true
  enabledAt   DateTime? @db.Timestamptz
  
  // Timestamp when the feature was disabled
  // Set when isActive changes from true to false
  disabledAt  DateTime? @db.Timestamptz
  
  // Admin/SuperAdmin user ID who last modified this access
  updatedBy   String?   @db.Uuid
  
  // Timestamp when this access record was created
  createdAt   DateTime  @default(now()) @db.Timestamptz
  
  // Timestamp automatically updated on every modification
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  // --- Relations ---
  // Organization this access belongs to (deleted if org is deleted)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  // User this access is assigned to (null for org-level, deleted if user is deleted)
  user         User?        @relation("UserFeatureAccess", fields: [userId], references: [id], onDelete: Cascade)
  
  // Feature this access controls (deleted if feature is deleted)
  feature      Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)
  
  // Admin/SuperAdmin who last modified this access
  updater      User?        @relation("FeatureAccessUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Unique constraint: one access record per org+user+feature combination
  @@unique([orgId, userId, featureId])
  
  // Indexes for faster lookups
  @@index([orgId])        // Find all features for an organization
  @@index([userId])       // Find all features for a specific user
  @@index([featureId])    // Find all access records for a feature
}